# id values such as {item_id}: when using a url specified in this configuration, the {id} will be replaced by the corresponding item id. 

# ***** APP CONFIGURATION *****
NODE_ENV={node runtime environment}
PORT={node port}

# ***** EXHIBITS CONFIGURATION *****
EXHIBITS_API_KEY={key to provide access to api protected routes. e.g. [api endpoint]?key=[api key]}

# ***** EXHIBITS IIIF CONFIGURATION *****
EXHIBITS_IIIF_DOMAIN={domain of iiif image server}

# ***** ELASTICSEARCH CONFIGURATION *****
ELASTIC_DOMAIN={domain of elastic server}
ELASTIC_INDEX={name of elastic index}

# ***** REPOSITORY CONFIGURATION ***** 
REPOSITORY_DOMAIN={domain of repository api}
REPOSITORY_API_KEY={repository api key}
REPOSITORY_SEARCH_ENDPOINT={url for respository search api. e.g. "https://specialcollections.du.edu/repository/search"}
REPOSITORY_ITEM_DATA_ENDPOINT={datastream endpoint for respository data (or, the url to the index document). e.g. "https://specialcollections.du.edu/object/{object_id}" or "[elastic domain]/[index name]/_doc/{item_id}}
REPOSITORY_OBJECT_PAGE_URL={url for object view/viewer. id values: '{item_id}' e.g. "https://specialcollections.du.edu/object/{item_id}"}
REPOSITORY_COLLECTION_PAGE_URL={url for collection page. id values: '{collection_id}' e.g. "https://specialcollections.du.edu/collection/{collection_id}"}

#***** REPOSITORY RESOURCE DATASTREAM CONFIGURATION *****
REPOSITORY_ITEM_RESOURCE_ENDPOINT={uri to repository item resource file (main resource or object file). this uri should return the file as a stream}
REPOSITORY_ITEM_THUMBNAIL_ENDPOINT={uri to repository item thumbnail image file. this uri should return the file as a stream}

# ***** REPOSITORY IIIF CONFIGURATION *****
REPOSITORY_IIIF_SERVICE_URL={repository iiif service url: id values: '{item_id}' for iiif api identifier e.g. "https://specialcollections.du.edu/cantaloupe-digitaldu/{item_id}"}
REPOSITORY_IIIF_IMAGE_URL={repository iiif service url: id values: '{item_id}' for iiif api identifier e.g. "https://specialcollections.du.edu/cantaloupe-digitaldu/{item_id}/full/max/0/default.jpg"}
REPOSITORY_IIIF_MANIFEST_URL={repository iiif service url: id values: '{item_id}' for iiif api identifier e.g. "https://specialcollections.du.edu/iiif/{item_id}/manifest"}
REPOSITORY_IIIF_THUMBNAIL_URL={repository iiif thumbnail url: id values: '{item_id}' for iiif api identifier e.g. "https://specialcollections.du.edu/cantaloupe-digitaldu/{item_id}/full/400,/0/default.jpg"}

# ***** LOCAL FILE STORAGE CONFIGURATION *****
RESOURCE_LOCATION={location of exhibits app client resource storage e.g. client/public/storage}

# ***** EXTERNAL LINKS FOR EXHIBIT ITEM DATA *****
ARCHIVAL_METADATA_PROVIDER_DOMAIN={domain of archival data api}